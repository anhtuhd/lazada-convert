# ============================================================
#  Environment Variables — Lazada Affiliate Link Converter
# ============================================================
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# Lazada App Console: https://isvconsole.lazada.com/apps/console/apps
LAZADA_APP_KEY=your_app_key_here
LAZADA_APP_SECRET=your_app_secret_here

# OAuth 2.0 Access Token for your Affiliate account
# How to get: https://open.lazada.com/apps/doc/doc?docId=108067
LAZADA_ACCESS_TOKEN=your_access_token_here

# Gateway URL — change based on target country:
#   Vietnam    : https://api.lazada.com/rest
#   Singapore  : https://api.lazada.sg/rest
#   Malaysia   : https://api.lazada.com.my/rest
#   Thailand   : https://api.lazada.co.th/rest
#   Philippines: https://api.lazada.com.ph/rest
#   Indonesia  : https://api.lazada.co.id/rest
LAZADA_GATEWAY_URL=https://api.lazada.com/rest
